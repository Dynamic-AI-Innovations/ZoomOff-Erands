# ZoomOff Web Platform — Environment Variables
# Copy this file to .env.local in each app directory and fill in values

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.zoomoff.africa/api/v1
NEXT_PUBLIC_WS_URL=wss://ws.zoomoff.africa

# ─── Google Maps ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Firebase (GPS tracking) ──────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ─── Paystack ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ─── Flutterwave ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=

# ─── Support Chat ────────────────────────────────────────────────────────────
NEXT_PUBLIC_INTERCOM_APP_ID=

# ─── Analytics ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Error Tracking ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
